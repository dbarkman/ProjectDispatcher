<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Metadata -->
  <div class="card">
    <h3 class="text-sm font-semibold text-gray-400 mb-4">Configuration</h3>
    <form hx-patch="/api/agent-types/{{agentType.id}}" hx-ext="json-enc" hx-swap="none"
          hx-on::after-request="if(event.detail.successful) location.reload()">
      <div class="space-y-3">
        <div>
          <label class="block text-xs text-gray-500 mb-1">Name</label>
          <input name="name" value="{{agentType.name}}"
            class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Description</label>
          <input name="description" value="{{agentType.description}}"
            class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Model</label>
          <input name="model" value="{{agentType.model}}"
            class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 font-mono text-xs focus:border-accent focus:outline-none">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Permission Mode</label>
            <select name="permission_mode"
              class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
              <option value="default" {{#if (eq agentType.permission_mode "default")}}selected{{/if}}>default</option>
              <option value="acceptEdits" {{#if (eq agentType.permission_mode "acceptEdits")}}selected{{/if}}>acceptEdits</option>
              <option value="bypassPermissions" {{#if (eq agentType.permission_mode "bypassPermissions")}}selected{{/if}}>bypassPermissions</option>
              <option value="plan" {{#if (eq agentType.permission_mode "plan")}}selected{{/if}}>plan</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Timeout (min)</label>
            <input name="timeout_minutes" type="number" value="{{agentType.timeout_minutes}}"
              class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
          </div>
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Tools</label>
          <div class="flex flex-wrap gap-1">
            {{#each tools}}
            <span class="bg-navy-700 text-gray-300 text-xs px-2 py-1 rounded">{{this}}</span>
            {{/each}}
          </div>
        </div>
      </div>
      <button type="submit"
        class="mt-4 px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">
        Save Configuration
      </button>
    </form>
  </div>

  <!-- System Prompt -->
  <div class="card">
    <h3 class="text-sm font-semibold text-gray-400 mb-4">System Prompt</h3>
    <form hx-patch="/api/agent-types/{{agentType.id}}" hx-ext="json-enc" hx-swap="none"
          hx-on::after-request="if(event.detail.successful) location.reload()">
      <textarea name="prompt_text" rows="20"
        class="w-full bg-navy-900 border border-navy-700 rounded-lg p-3 text-sm text-gray-200 font-mono leading-relaxed placeholder-gray-600 focus:border-accent focus:outline-none resize-y"
        placeholder="System prompt for this agent type...">{{promptText}}</textarea>
      <button type="submit"
        class="mt-3 px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">
        Save Prompt
      </button>
    </form>
  </div>
</div>

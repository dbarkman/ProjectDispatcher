<!-- Board actions -->
<div class="flex gap-3 mb-6">
  <button onclick="document.getElementById('new-ticket-form').classList.toggle('hidden')"
    class="px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">
    + New Ticket
  </button>
  <form hx-post="/api/projects/{{project.id}}/wake" hx-ext="json-enc" hx-swap="none"
        hx-on::after-request="if(event.detail.successful) { alert('Heartbeat reset — agents will check soon'); }">
    <button type="submit"
      class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-200 text-sm rounded-lg transition-colors">
      Wake
    </button>
  </form>
  <a href="/ui/settings" class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-200 text-sm rounded-lg transition-colors inline-flex items-center">
    App Settings
  </a>
  <button onclick="if(confirm('Archive this project? It will be hidden from the project list but tickets are preserved.')) { fetch('/api/projects/{{project.id}}', {method:'DELETE'}).then(r => { if(r.ok) window.location='/ui/projects'; else r.json().then(d => alert(d.error)); }); }"
    class="px-4 py-2 bg-navy-800 hover:bg-red-900/50 text-gray-400 hover:text-red-400 text-sm rounded-lg transition-colors ml-auto">
    Archive Project
  </button>
</div>

<!-- New Ticket form (hidden by default) -->
<div id="new-ticket-form" class="hidden mb-6 card">
  <h3 class="text-sm font-semibold text-gray-400 mb-3">New Ticket</h3>
  <form id="create-ticket-form" onsubmit="return submitTicketForm(event)">
    <input type="hidden" name="project_id" value="{{project.id}}">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Title</label>
        <input name="title" required placeholder="What needs to be done?"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Priority</label>
        <select name="priority"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
          <option value="normal">Normal</option>
          <option value="low">Low</option>
          <option value="high">High</option>
          <option value="urgent">Urgent</option>
        </select>
      </div>
    </div>
    <div class="mt-3">
      <label class="block text-xs text-gray-500 mb-1">Description (optional)</label>
      <textarea name="body" rows="3" placeholder="Details, acceptance criteria, context..."
        class="w-full bg-navy-900 border border-navy-700 rounded-lg p-3 text-sm text-gray-200 placeholder-gray-600 focus:border-accent focus:outline-none resize-y"></textarea>
    </div>
    <div class="mt-3">
      <label class="block text-xs text-gray-500 mb-1">Screenshots (optional)</label>
      <div id="screenshot-drop-zone"
        class="border-2 border-dashed border-navy-700 rounded-lg p-4 text-center cursor-pointer hover:border-accent/50 transition-colors"
        onclick="document.getElementById('screenshot-input').click()">
        <p class="text-sm text-gray-500">Click to select or drag & drop images here</p>
        <p class="text-xs text-gray-600 mt-1">PNG, JPEG, GIF, WebP. Max 10 MB each.</p>
      </div>
      <input type="file" id="screenshot-input" accept="image/*" multiple class="hidden"
        onchange="handleFileSelect(this.files)">
      <div id="screenshot-previews" class="flex flex-wrap gap-2 mt-2"></div>
    </div>
    <div class="mt-3 flex gap-2">
      <button type="submit" id="create-ticket-btn" class="px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">Create Ticket</button>
      <button type="button" onclick="document.getElementById('new-ticket-form').classList.add('hidden')" class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-300 text-sm rounded-lg transition-colors">Cancel</button>
    </div>
  </form>
</div>
<script>
  const pendingFiles = [];

  function handleFileSelect(files) {
    for (const file of files) {
      if (!file.type.startsWith('image/')) continue;
      if (file.size > 10 * 1024 * 1024) {
        alert(file.name + ' is too large (max 10 MB)');
        continue;
      }
      pendingFiles.push(file);
      addPreview(file, pendingFiles.length - 1);
    }
    // Reset the input so re-selecting the same file works
    document.getElementById('screenshot-input').value = '';
  }

  function addPreview(file, index) {
    const container = document.getElementById('screenshot-previews');
    const wrapper = document.createElement('div');
    wrapper.className = 'relative group';
    wrapper.dataset.index = index;

    const img = document.createElement('img');
    img.className = 'h-16 w-16 object-cover rounded border border-navy-700';
    const url = URL.createObjectURL(file);
    img.src = url;
    img.onload = function() { URL.revokeObjectURL(url); };

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'absolute -top-1 -right-1 bg-red-600 text-white rounded-full w-4 h-4 text-xs leading-none flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity';
    removeBtn.textContent = '\u00d7';
    removeBtn.onclick = function(e) {
      e.stopPropagation();
      pendingFiles[index] = null;
      wrapper.remove();
    };

    wrapper.appendChild(img);
    wrapper.appendChild(removeBtn);
    container.appendChild(wrapper);
  }

  // Drag and drop on the drop zone
  const dropZone = document.getElementById('screenshot-drop-zone');
  dropZone.addEventListener('dragover', function(e) {
    e.preventDefault();
    dropZone.classList.add('border-accent/50');
  });
  dropZone.addEventListener('dragleave', function() {
    dropZone.classList.remove('border-accent/50');
  });
  dropZone.addEventListener('drop', function(e) {
    e.preventDefault();
    dropZone.classList.remove('border-accent/50');
    if (e.dataTransfer.files.length) handleFileSelect(e.dataTransfer.files);
  });

  async function submitTicketForm(e) {
    e.preventDefault();
    const form = document.getElementById('create-ticket-form');
    const btn = document.getElementById('create-ticket-btn');
    btn.disabled = true;
    btn.textContent = 'Creating...';

    try {
      // Step 1: Create the ticket via JSON
      const formData = new FormData(form);
      const ticketData = {
        project_id: formData.get('project_id'),
        title: formData.get('title'),
        body: formData.get('body') || undefined,
        priority: formData.get('priority'),
      };

      const res = await fetch('/api/tickets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(ticketData),
      });

      if (!res.ok) {
        const err = await res.json();
        alert('Failed to create ticket: ' + (err.error || 'Unknown error'));
        return false;
      }

      const ticket = await res.json();

      // Step 2: Upload any pending screenshots
      const filesToUpload = pendingFiles.filter(function(f) { return f !== null; });
      for (const file of filesToUpload) {
        const uploadData = new FormData();
        uploadData.append('file', file);
        await fetch('/api/tickets/' + ticket.id + '/attachments', {
          method: 'POST',
          body: uploadData,
        });
      }

      location.reload();
    } catch (err) {
      alert('Error: ' + err.message);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Create Ticket';
    }
    return false;
  }
</script>

<!-- Drag-and-drop script (Gap fix #4) -->
<script>
  let draggedTicketId = null;

  function onDragStart(e, ticketId) {
    draggedTicketId = ticketId;
    e.dataTransfer.effectAllowed = 'move';
    e.target.style.opacity = '0.5';
  }

  function onDragEnd(e) {
    e.target.style.opacity = '1';
    draggedTicketId = null;
  }

  function onDragOver(e) {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    e.currentTarget.classList.add('ring-2', 'ring-accent/30');
  }

  function onDragLeave(e) {
    e.currentTarget.classList.remove('ring-2', 'ring-accent/30');
  }

  async function onDrop(e, columnId) {
    e.preventDefault();
    e.currentTarget.classList.remove('ring-2', 'ring-accent/30');
    if (!draggedTicketId) return;

    try {
      const res = await fetch(`/api/tickets/${draggedTicketId}/move`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ to_column: columnId, author: 'human' }),
      });
      if (res.ok) {
        location.reload();
      } else {
        const err = await res.json();
        alert(`Move failed: ${err.error || 'Unknown error'}`);
      }
    } catch (err) {
      alert('Move failed: network error');
    }
  }
</script>

<!-- Kanban board -->
<div class="flex gap-4 overflow-x-auto pb-4" style="min-height: 400px;">
  {{#each columns}}
  <div class="flex-shrink-0 w-72">
    <div class="flex items-center justify-between mb-3 px-1">
      <h3 class="text-sm font-semibold
        {{#if this.isHuman}}text-gray-300{{/if}}
        {{#if this.isAgent}}text-accent{{/if}}
        {{#if this.isDone}}text-green-400{{/if}}
      ">
        {{this.name}}
      </h3>
      <span class="text-xs text-gray-500">{{this.tickets.length}}</span>
    </div>
    <div class="space-y-2 min-h-[200px] rounded-lg p-2 transition-all
      {{#if this.isHuman}}bg-navy-900/50{{/if}}
      {{#if this.isAgent}}bg-navy-800/30 border border-accent/10{{/if}}
      {{#if this.isDone}}bg-navy-900/30 border border-green-900/20{{/if}}
    "
      data-column="{{this.column_id}}"
      ondragover="onDragOver(event)"
      ondragleave="onDragLeave(event)"
      ondrop="onDrop(event, '{{this.column_id}}')"
    >
      {{#each this.tickets}}
      <div class="card cursor-grab hover:border-accent/30 active:cursor-grabbing"
           draggable="true"
           ondragstart="onDragStart(event, '{{this.id}}')"
           ondragend="onDragEnd(event)"
           onclick="if(!window.getSelection().toString()) window.location='/ui/tickets/{{this.id}}'">
        <div class="flex items-start justify-between gap-2">
          <p class="text-sm text-gray-200 leading-snug">{{this.title}}</p>
          <span class="priority-dot priority-{{this.priority}} shrink-0 mt-1"></span>
        </div>
        <div class="flex items-center gap-2 mt-2 text-xs text-gray-500">
          <span class="status-dot status-dot-{{this.statusColor}}" title="Status: {{this.statusColor}}"></span>
          <span>{{this.shortId}}</span>
          {{#if this.isClaimed}}
          <span class="text-accent" title="Agent is working on this">&#9881;</span>
          {{/if}}
          <span class="ml-auto">{{relativeTime this.updated_at}}</span>
        </div>
      </div>
      {{else}}
      <div class="text-xs text-gray-600 text-center py-8">No tickets</div>
      {{/each}}
    </div>
  </div>
  {{/each}}
</div>

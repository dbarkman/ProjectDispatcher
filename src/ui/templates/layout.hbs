<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{#if title}}{{title}} — {{/if}}Project Dispatcher</title>
  <script src="/static/vendor/tailwind.js"></script>
  <script src="/static/vendor/htmx-2.0.4.js"></script>
  <script src="/static/vendor/htmx-json-enc-2.0.3.js"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            // Linode-inspired neutral gray palette — lighter, no black
            navy: {
              50: '#f5f5f5',
              100: '#d4d4d4',
              200: '#a3a3a3',
              300: '#737373',
              400: '#5c5c5c',
              500: '#4a4a4a',
              600: '#414141',
              700: '#383838',
              800: '#2e2e2e',
              900: '#262626',
              950: '#1e1e1e',
            },
            accent: {
              DEFAULT: '#02b159',
              hover: '#029a4d',
            },
          },
        },
      },
    };
  </script>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body class="dark h-full bg-navy-950 text-gray-200">
  <div class="flex h-full">
    <!-- Mobile sidebar backdrop -->
    <div id="sidebar-backdrop" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden" onclick="closeMobileSidebar()"></div>
    <!-- Sidebar (Gap fix #7 — collapsible, mobile-responsive) -->
    <aside id="sidebar" class="w-56 bg-navy-900 border-r border-navy-700 flex flex-col shrink-0 transition-all duration-200 fixed inset-y-0 left-0 z-40 -translate-x-full md:translate-x-0 md:static md:z-auto">
      <!-- Logo + collapse toggle -->
      <div class="px-4 py-4 border-b border-navy-700 flex items-center justify-between">
        <div class="sidebar-expanded">
          <h1 class="text-lg font-bold text-white tracking-tight">Dispatch</h1>
          <p class="text-xs text-gray-400">Project Dispatcher</p>
        </div>
        <button onclick="toggleSidebar()" class="text-gray-500 hover:text-gray-300 text-sm" title="Toggle sidebar">
          <span id="collapse-icon">&#9664;</span>
        </button>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 py-3 overflow-y-auto">
        <ul class="space-y-0.5 px-2">
          <li>
            <a href="/"
               class="nav-link {{#if (eq activePage 'inbox')}}nav-link-active{{/if}}">
              <span class="nav-icon">&#9993;</span>
              <span class="nav-label">Inbox</span>
              {{#if inboxCount}}<span class="ml-auto bg-accent text-white text-xs px-1.5 py-0.5 rounded-full">{{inboxCount}}</span>{{/if}}
            </a>
          </li>
          <li>
            <a href="/ui/projects"
               class="nav-link {{#if (eq activePage 'projects')}}nav-link-active{{/if}}">
              <span class="nav-icon">&#128193;</span>
              <span class="nav-label">Projects</span>
            </a>
          </li>
          <li>
            <a href="/ui/agent-types"
               class="nav-link {{#if (eq activePage 'agent-types')}}nav-link-active{{/if}}">
              <span class="nav-icon">&#129302;</span>
              <span class="nav-label">Agent Types</span>
            </a>
          </li>
          <li>
            <a href="/ui/settings"
               class="nav-link {{#if (eq activePage 'settings')}}nav-link-active{{/if}}">
              <span class="nav-icon">&#9881;</span>
              <span class="nav-label">Settings</span>
            </a>
          </li>
        </ul>
      </nav>

      <!-- Version -->
      <div class="px-4 py-3 border-t border-navy-700 text-xs text-gray-500">
        v0.0.1
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
      <!-- Top bar -->
      <header class="sticky top-0 z-10 bg-navy-900 border-b border-navy-700 px-3 md:px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <button id="hamburger" class="md:hidden text-gray-400 hover:text-white text-xl leading-none" onclick="openMobileSidebar()" title="Open menu">&#9776;</button>
          <div>
            {{#if breadcrumbs}}
            <nav class="text-sm text-gray-400">
              {{#each breadcrumbs}}
              {{#if @last}}
                <span class="text-gray-200">{{this.label}}</span>
              {{else}}
                <a href="{{this.href}}" class="hover:text-gray-200">{{this.label}}</a>
                <span class="mx-1">/</span>
              {{/if}}
              {{/each}}
            </nav>
            {{/if}}
            {{#if pageTitle}}
            <h2 class="text-xl font-semibold text-white mt-0.5">{{pageTitle}}</h2>
            {{/if}}
          </div>
        </div>
        {{!-- Actions slot removed: the {{{actions}}} triple-brace was an
             XSS-prone pattern. When action buttons are needed, add them as
             structured data (array of {label, href} objects) rendered with
             {{#each}} and double-braces. (Review #9 L1 / MEDIUM) --}}
      </header>

      <!-- Page content -->
      <div class="p-3 md:p-6">
        {{{body}}}
      </div>
    </main>
  </div>
  <!-- Sidebar collapse + mobile responsive script -->
  <script>
    const isMobile = () => window.innerWidth < 768;

    const openMobileSidebar = () => {
      const sidebar = document.getElementById('sidebar');
      const backdrop = document.getElementById('sidebar-backdrop');
      sidebar.classList.remove('w-16');
      sidebar.classList.add('w-56');
      document.getElementById('collapse-icon').innerHTML = '&#9664;';
      document.querySelectorAll('.sidebar-expanded').forEach(el => el.style.display = '');
      document.querySelectorAll('.nav-label').forEach(el => el.style.display = '');
      sidebar.classList.remove('-translate-x-full');
      sidebar.classList.add('translate-x-0');
      backdrop.classList.remove('hidden');
    };

    const closeMobileSidebar = () => {
      const sidebar = document.getElementById('sidebar');
      const backdrop = document.getElementById('sidebar-backdrop');
      sidebar.classList.add('-translate-x-full');
      sidebar.classList.remove('translate-x-0');
      backdrop.classList.add('hidden');
    };

    const toggleSidebar = () => {
      if (isMobile()) {
        closeMobileSidebar();
        return;
      }
      const sidebar = document.getElementById('sidebar');
      const icon = document.getElementById('collapse-icon');
      const expanded = document.querySelectorAll('.sidebar-expanded');
      const labels = document.querySelectorAll('.nav-label');

      if (sidebar.classList.contains('w-56')) {
        sidebar.classList.remove('w-56');
        sidebar.classList.add('w-16');
        icon.innerHTML = '&#9654;';
        expanded.forEach(el => el.style.display = 'none');
        labels.forEach(el => el.style.display = 'none');
      } else {
        sidebar.classList.remove('w-16');
        sidebar.classList.add('w-56');
        icon.innerHTML = '&#9664;';
        expanded.forEach(el => el.style.display = '');
        labels.forEach(el => el.style.display = '');
      }
    };

    window.addEventListener('resize', () => {
      if (!isMobile()) {
        closeMobileSidebar();
      }
    });
  </script>
</body>
</html>

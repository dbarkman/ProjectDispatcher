{{#if projects.length}}
<div class="mb-4">
  <button onclick="document.getElementById('inbox-new-ticket').classList.toggle('hidden')"
    class="px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">
    + New Ticket
  </button>
</div>
<div id="inbox-new-ticket" class="hidden mb-6 card">
  <h3 class="text-sm font-semibold text-gray-400 mb-3">New Ticket</h3>
  <form id="inbox-ticket-form" onsubmit="return submitInboxTicket(event)">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Project</label>
        <select name="project_id" required
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
          {{#each projects}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Title</label>
        <input name="title" required placeholder="What needs to be done?"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Priority</label>
        <select name="priority"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
          <option value="normal">Normal</option>
          <option value="low">Low</option>
          <option value="high">High</option>
          <option value="urgent">Urgent</option>
        </select>
      </div>
    </div>
    <div class="mt-3">
      <textarea name="body" rows="2" placeholder="Description (optional)"
        class="w-full bg-navy-900 border border-navy-700 rounded-lg p-3 text-sm text-gray-200 placeholder-gray-600 focus:border-accent focus:outline-none resize-y"></textarea>
    </div>
    <div class="mt-2 flex gap-2">
      <button type="submit" id="inbox-ticket-btn" class="px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">Create</button>
      <button type="button" onclick="document.getElementById('inbox-new-ticket').classList.add('hidden')" class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-300 text-sm rounded-lg transition-colors">Cancel</button>
    </div>
  </form>
</div>
<script>
  async function submitInboxTicket(e) {
    e.preventDefault();
    var form = document.getElementById('inbox-ticket-form');
    var btn = document.getElementById('inbox-ticket-btn');
    btn.disabled = true;
    btn.textContent = 'Creating...';
    try {
      var res = await fetch('/api/tickets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          project_id: form.querySelector('[name=project_id]').value,
          title: form.querySelector('[name=title]').value,
          body: form.querySelector('[name=body]').value || undefined,
          priority: form.querySelector('[name=priority]').value,
        }),
      });
      if (res.ok) {
        document.getElementById('inbox-new-ticket').classList.add('hidden');
        location.reload();
      } else {
        var data = await res.json().catch(function() { return {}; });
        alert('Failed to create ticket: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Error: ' + err.message);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Create';
    }
    return false;
  }
</script>
{{/if}}

{{#if isEmpty}}
<div class="flex flex-col items-center justify-center py-20 text-center">
  <div class="text-5xl mb-4">&#10003;</div>
  <h3 class="text-xl font-semibold text-gray-300 mb-2">All clear!</h3>
  <p class="text-gray-500 max-w-md">No tickets waiting for your attention. Agents are either working or there's nothing in the queue.</p>
</div>
{{else}}
<!-- Filter bar (Gap fix #6) -->
<div class="flex flex-wrap items-center gap-4 mb-4">
  <span class="text-sm text-gray-400">
    {{tickets.length}} ticket{{#unless (eq tickets.length 1)}}s{{/unless}} waiting
  </span>
  <div class="flex flex-wrap gap-2 ml-auto">
    <select id="inbox-filter-project" onchange="filterInbox()"
      class="bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-300 focus:border-accent focus:outline-none">
      <option value="">All projects</option>
      {{#each projects}}
      <option value="{{this.name}}">{{this.name}}</option>
      {{/each}}
    </select>
    <select id="inbox-filter-priority" onchange="filterInbox()"
      class="bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-300 focus:border-accent focus:outline-none">
      <option value="">All priorities</option>
      <option value="urgent">Urgent</option>
      <option value="high">High</option>
      <option value="normal">Normal</option>
      <option value="low">Low</option>
    </select>
    <select id="inbox-sort" onchange="sortInbox()"
      class="bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-300 focus:border-accent focus:outline-none">
      <option value="age-desc">Newest first</option>
      <option value="age-asc">Oldest first</option>
      <option value="priority">Priority</option>
      <option value="project">Project</option>
    </select>
  </div>
</div>

<script>
  const priorityOrder = { urgent: 0, high: 1, normal: 2, low: 3 };

  function filterInbox() {
    const project = document.getElementById('inbox-filter-project').value;
    const priority = document.getElementById('inbox-filter-priority').value;
    const rows = document.querySelectorAll('#inbox-table tbody tr');
    rows.forEach(row => {
      const rProject = row.dataset.project || '';
      const rPriority = row.dataset.priority || '';
      const matchProject = !project || rProject === project;
      const matchPriority = !priority || rPriority === priority;
      row.style.display = (matchProject && matchPriority) ? '' : 'none';
    });
  }

  function sortInbox() {
    const sortBy = document.getElementById('inbox-sort').value;
    const tbody = document.querySelector('#inbox-table tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    rows.sort((a, b) => {
      if (sortBy === 'age-asc') return parseInt(a.dataset.updated) - parseInt(b.dataset.updated);
      if (sortBy === 'age-desc') return parseInt(b.dataset.updated) - parseInt(a.dataset.updated);
      if (sortBy === 'priority') return (priorityOrder[a.dataset.priority] || 2) - (priorityOrder[b.dataset.priority] || 2);
      if (sortBy === 'project') return (a.dataset.project || '').localeCompare(b.dataset.project || '');
      return 0;
    });
    rows.forEach(row => tbody.appendChild(row));
  }
</script>

<div class="overflow-x-auto">
  <table id="inbox-table" class="w-full text-sm">
    <thead>
      <tr class="border-b border-navy-700 text-left text-gray-400">
        <th class="pb-3 pr-4 font-medium w-24">ID</th>
        <th class="pb-3 pr-4 font-medium">Project</th>
        <th class="pb-3 pr-4 font-medium">Title</th>
        <th class="pb-3 pr-4 font-medium w-20">Priority</th>
        <th class="pb-3 font-medium w-20">Age</th>
      </tr>
    </thead>
    <tbody>
      {{#each tickets}}
      <tr class="border-b border-navy-800 hover:bg-navy-800/50 cursor-pointer"
          data-project="{{this.projectName}}" data-priority="{{this.priority}}" data-updated="{{this.updated_at}}"
          onclick="window.location='/ui/tickets/{{this.id}}'">
        <td class="py-3 pr-4">
          <span class="text-gray-300 text-xs font-mono">{{this.displayId}}</span>
        </td>
        <td class="py-3 pr-4">
          <span class="text-accent text-xs font-mono">[{{this.projectName}}]</span>
        </td>
        <td class="py-3 pr-4 text-gray-200">
          {{this.title}}
        </td>
        <td class="py-3 pr-4">
          <span class="priority-dot priority-{{this.priority}}"></span>
          <span class="text-gray-400 text-xs ml-1">{{this.priority}}</span>
        </td>
        <td class="py-3 text-gray-500 text-xs">
          {{relativeTime this.updated_at}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{/if}}

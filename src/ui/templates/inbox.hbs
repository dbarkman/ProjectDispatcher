{{#if projects.length}}
<div class="mb-4">
  <button onclick="document.getElementById('inbox-new-ticket').classList.toggle('hidden')"
    class="px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">
    + New Ticket
  </button>
</div>
<div id="inbox-new-ticket" class="hidden mb-6 card">
  <h3 class="text-sm font-semibold text-gray-400 mb-3">New Ticket</h3>
  <form hx-post="/api/tickets" hx-ext="json-enc" hx-swap="none"
        hx-on::after-request="if(event.detail.successful) location.reload()">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Project</label>
        <select name="project_id" required
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
          {{#each projects}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Title</label>
        <input name="title" required placeholder="What needs to be done?"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Priority</label>
        <select name="priority"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
          <option value="normal">Normal</option>
          <option value="low">Low</option>
          <option value="high">High</option>
          <option value="urgent">Urgent</option>
        </select>
      </div>
    </div>
    <div class="mt-3">
      <textarea name="body" rows="2" placeholder="Description (optional)"
        class="w-full bg-navy-900 border border-navy-700 rounded-lg p-3 text-sm text-gray-200 placeholder-gray-600 focus:border-accent focus:outline-none resize-y"></textarea>
    </div>
    <div class="mt-2 flex gap-2">
      <button type="submit" class="px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">Create</button>
      <button type="button" onclick="document.getElementById('inbox-new-ticket').classList.add('hidden')" class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-300 text-sm rounded-lg transition-colors">Cancel</button>
    </div>
  </form>
</div>
{{/if}}

{{#if isEmpty}}
<div class="flex flex-col items-center justify-center py-20 text-center">
  <div class="text-5xl mb-4">&#10003;</div>
  <h3 class="text-xl font-semibold text-gray-300 mb-2">All clear!</h3>
  <p class="text-gray-500 max-w-md">No tickets waiting for your attention. Agents are either working or there's nothing in the queue.</p>
</div>
{{else}}
<div class="mb-4 text-sm text-gray-400">
  {{tickets.length}} ticket{{#unless (eq tickets.length 1)}}s{{/unless}} waiting
</div>

<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-navy-700 text-left text-gray-400">
        <th class="pb-3 pr-4 font-medium">Project</th>
        <th class="pb-3 pr-4 font-medium">Title</th>
        <th class="pb-3 pr-4 font-medium w-20">Priority</th>
        <th class="pb-3 font-medium w-20">Age</th>
      </tr>
    </thead>
    <tbody>
      {{#each tickets}}
      <tr class="border-b border-navy-800 hover:bg-navy-800/50 cursor-pointer"
          onclick="window.location='/ui/tickets/{{this.id}}'">
        <td class="py-3 pr-4">
          <span class="text-accent text-xs font-mono">[{{this.projectName}}]</span>
        </td>
        <td class="py-3 pr-4 text-gray-200">
          {{this.title}}
        </td>
        <td class="py-3 pr-4">
          <span class="priority-dot priority-{{this.priority}}"></span>
          <span class="text-gray-400 text-xs ml-1">{{this.priority}}</span>
        </td>
        <td class="py-3 text-gray-500 text-xs">
          {{relativeTime this.updated_at}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{/if}}

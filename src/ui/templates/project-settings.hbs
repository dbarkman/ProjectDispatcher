<div class="max-w-2xl">
  <div class="card">
    <h3 class="text-sm font-semibold text-gray-300 mb-1">Project Settings</h3>
    <p class="text-xs text-gray-500 mb-4">
      Edit basic project metadata. Workflow columns + agents live on the
      <a href="/ui/projects/{{project.id}}/workflow" class="text-accent hover:text-accent-hover">workflow editor</a>.
    </p>

    <form hx-patch="/api/projects/{{project.id}}" hx-ext="json-enc" hx-swap="none"
          hx-on::before-request="document.getElementById('settings-status').textContent = ''; document.getElementById('settings-status').className = 'text-xs text-gray-500';"
          hx-on::after-request="handleSettingsResponse(event)">
      <div class="space-y-3">
        <div>
          <label class="block text-xs text-gray-500 mb-1">Name</label>
          <input name="name" value="{{project.name}}" required maxlength="200"
            class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
        </div>

        <div>
          <label class="block text-xs text-gray-500 mb-1">
            Abbreviation
            <span class="text-gray-600">(used in ticket ids: <code>{{project.abbreviation}}</code>-1, -2…)</span>
          </label>
          <input name="abbreviation" value="{{project.abbreviation}}" required
            pattern="[a-z0-9]+" maxlength="12"
            class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 font-mono focus:border-accent focus:outline-none">
          <p class="text-[10px] text-gray-500 mt-1">
            Lowercase letters and numbers, max 12. Renaming to a value already used by
            another active project returns 409 (no silent suffix on edit).
          </p>
        </div>

        <div>
          <label class="block text-xs text-gray-500 mb-1">Path</label>
          <input name="path" value="{{project.path}}" required
            class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 font-mono focus:border-accent focus:outline-none">
          <p class="text-[10px] text-gray-500 mt-1">
            Filesystem path the discovery loop watches. Changing this points the project
            at a different folder; existing tickets stay attached. Renaming to a path
            already used by another active project returns 409 (no overwrite).
          </p>
        </div>

        <div>
          <label class="block text-xs text-gray-500 mb-1">Project Type (template)</label>
          <input value="{{projectTypeName}}" disabled
            class="w-full bg-navy-950 border border-navy-800 rounded px-3 py-2 text-sm text-gray-500">
          <p class="text-[10px] text-gray-500 mt-1">
            Read-only. The project's workflow was cloned from this template at registration.
            Switching templates is a separate operation (not implemented yet).
          </p>
        </div>
      </div>

      <div class="flex items-center gap-2 mt-4">
        <button type="submit"
          class="px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">
          Save Changes
        </button>
        <a href="/ui/projects/{{project.id}}"
          class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-300 text-sm rounded-lg transition-colors">
          Cancel
        </a>
        <span id="settings-status" class="text-xs text-gray-500 ml-2"></span>
      </div>
    </form>
  </div>

  <div class="card mt-4 border border-red-900/60">
    <h3 class="text-sm font-semibold text-red-400 mb-2">Danger Zone</h3>
    <p class="text-xs text-gray-500 mb-3">
      Archive removes the project from active lists; tickets and history are preserved.
      Re-registering the same folder later starts a new project (this one stays archived).
    </p>
    <button type="button" onclick="archiveProject()"
      class="px-4 py-2 bg-navy-800 hover:bg-red-900/50 text-gray-400 hover:text-red-400 text-sm rounded-lg transition-colors">
      Archive Project
    </button>
  </div>
</div>

<script>
  function handleSettingsResponse(event) {
    var xhr = event.detail.xhr;
    if (xhr && xhr.status >= 200 && xhr.status < 300) return;
    var status = document.getElementById('settings-status');
    var msg = 'Save failed.';
    try {
      var body = JSON.parse(xhr.responseText);
      if (body && body.error) msg = body.error;
    } catch (e) { /* keep generic */ }
    status.textContent = msg;
    status.className = 'text-xs text-red-400 ml-2';
  }

  function archiveProject() {
    if (!confirm('Archive this project? Tickets and history are preserved; the project is removed from active lists.')) return;
    fetch('/api/projects/{{project.id}}', { method: 'DELETE' })
      .then(function (r) {
        if (r.ok) window.location = '/ui/projects';
        else r.json().then(function (d) { alert(d.error || 'Archive failed'); });
      });
  }
</script>

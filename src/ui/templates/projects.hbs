<!-- Register Project form -->
<div class="mb-6 card">
  <h3 class="text-sm font-semibold text-gray-400 mb-3">Register a Project</h3>
  <form hx-post="/api/projects" hx-ext="json-enc" hx-swap="none"
        hx-on::after-request="if(event.detail.successful) location.reload()">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Name</label>
        <input name="name" required placeholder="My Project"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Path</label>
        <input name="path" required placeholder="/Users/you/Development/my-project"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 font-mono text-xs focus:border-accent focus:outline-none">
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Type</label>
        <select name="project_type_id" required
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
          {{#each projectTypes}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    <button type="submit"
      class="mt-3 px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">
      Register
    </button>
  </form>

  {{#if discovered.length}}
  <div class="mt-4 pt-3 border-t border-navy-700">
    <p class="text-xs text-gray-500 mb-2">Discovered folders (not yet registered):</p>
    <div class="flex flex-wrap gap-2">
      {{#each discovered}}
      <span class="text-xs bg-navy-800 text-gray-400 px-2 py-1 rounded" title="{{this.path}}">{{this.name}}</span>
      {{/each}}
    </div>
  </div>
  {{/if}}
</div>

{{#if projects.length}}
<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-navy-700 text-left text-gray-400">
        <th class="pb-3 pr-4 font-medium">Name</th>
        <th class="pb-3 pr-4 font-medium">Type</th>
        <th class="pb-3 pr-4 font-medium w-24">Status</th>
        <th class="pb-3 font-medium">Path</th>
      </tr>
    </thead>
    <tbody>
      {{#each projects}}
      <tr class="border-b border-navy-800 hover:bg-navy-800/50 cursor-pointer"
          onclick="window.location='/ui/projects/{{this.id}}'">
        <td class="py-3 pr-4 text-gray-200 font-medium">{{this.name}}</td>
        <td class="py-3 pr-4 text-gray-400">{{this.project_type_id}}</td>
        <td class="py-3 pr-4">
          <span class="badge badge-{{this.status}}">{{this.status}}</span>
        </td>
        <td class="py-3 text-gray-500 text-xs font-mono">{{this.path}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{else}}
<div class="text-center py-12 text-gray-500">
  <p>No projects registered yet. Use the form above to register one.</p>
</div>
{{/if}}

{{#if discovered.length}}
<!-- Discovered folders — click to register -->
<div class="mb-6">
  <h3 class="text-sm font-semibold text-gray-400 mb-3">Discovered Projects</h3>
  <p class="text-xs text-gray-500 mb-3">Click a folder to add it as a project:</p>
  <div class="flex flex-wrap gap-3">
    {{#each discovered}}
    <div class="discovered-folder card flex items-center gap-3"
         onclick="showRegisterPrompt('{{this.name}}', '{{this.path}}')">
      <span class="text-2xl shrink-0">&#128193;</span>
      <div>
        <p class="text-sm text-gray-200 font-medium">{{this.name}}</p>
        <p class="text-xs text-gray-500 font-mono whitespace-nowrap">{{this.path}}</p>
      </div>
    </div>
    {{/each}}
  </div>
</div>

<!-- Register prompt modal (hidden until a discovered folder is clicked) -->
<div id="register-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
  <div class="bg-navy-800 border border-navy-700 rounded-xl w-96 p-6">
    <h3 class="text-lg font-semibold text-gray-200 mb-1">Register Project</h3>
    <p id="register-folder-name" class="text-sm text-gray-400 mb-4"></p>
    <form hx-post="/api/projects" hx-ext="json-enc" hx-swap="none"
          hx-on::before-request="document.getElementById('register-error').classList.add('hidden')"
          hx-on::after-request="handleRegisterResponse(event)">
      <input type="hidden" id="register-path" name="path">
      <div class="mb-3">
        <label class="block text-xs text-gray-500 mb-1">Name</label>
        <input id="register-name" name="name" required
          oninput="suggestAbbreviation(this.value)"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
      </div>
      <div class="mb-3">
        <label class="block text-xs text-gray-500 mb-1">
          Abbreviation
          <span class="text-gray-600">(used in ticket ids: <code id="register-abbr-preview">pd</code>-1, -2…)</span>
        </label>
        <input id="register-abbreviation" name="abbreviation" required
          pattern="[a-z0-9]+" maxlength="12"
          oninput="document.getElementById('register-abbr-preview').textContent = this.value || 'pd';"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 font-mono focus:border-accent focus:outline-none">
        <p class="text-[10px] text-gray-500 mt-1">
          Lowercase letters and numbers, max 12. Server appends a digit if it collides
          with another active project (pd, pd2, pd3...).
        </p>
      </div>
      <div class="mb-4">
        <label class="block text-xs text-gray-500 mb-1">Template</label>
        <select name="project_type_id" required
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
          {{#each projectTypes}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
          <option value="blank">— blank (build from scratch) —</option>
        </select>
        <p class="text-[10px] text-gray-500 mt-1">
          Templates are starting points. A private copy is made on registration —
          editing this project's workflow later won't affect the template or other projects.
        </p>
      </div>
      <div class="flex gap-2">
        <button type="submit"
          class="flex-1 px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">
          Add Project
        </button>
        <button type="button" onclick="document.getElementById('register-modal').classList.add('hidden')"
          class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-300 text-sm rounded-lg transition-colors">
          Cancel
        </button>
      </div>
      <!-- Server-error slot. htmx hides this before each submit; the
           after-request handler fills it from the response body on failure. -->
      <div id="register-error" class="hidden mt-3 text-xs text-red-400"></div>
    </form>
  </div>
</div>

<script>
  function showRegisterPrompt(name, path) {
    document.getElementById('register-name').value = name;
    document.getElementById('register-path').value = path;
    document.getElementById('register-folder-name').textContent = path;
    document.getElementById('register-error').classList.add('hidden');
    document.getElementById('register-error').textContent = '';
    suggestAbbreviation(name);
    document.getElementById('register-modal').classList.remove('hidden');
  }

  // Mirrors the server-side deriveAbbreviation rules well enough to give
  // a sensible default. Server still re-derives + checks uniqueness on
  // create — this is just UX prefill the user can edit.
  function suggestAbbreviation(name) {
    var trimmed = (name || '').trim();
    var abbr = '';
    var caps = trimmed.match(/[A-Z]/g);
    if (caps && caps.length >= 2) {
      abbr = caps.join('').toLowerCase().slice(0, 6);
    } else if (/[\s\-_]/.test(trimmed)) {
      abbr = trimmed.split(/[\s\-_]+/).filter(Boolean)
        .map(function (w) { return w[0] || ''; }).join('')
        .replace(/[^a-zA-Z0-9]/g, '').toLowerCase().slice(0, 6);
    }
    if (!abbr) {
      abbr = trimmed.toLowerCase().replace(/[^a-z0-9]/g, '').slice(0, 3) || 'p';
    }
    var input = document.getElementById('register-abbreviation');
    input.value = abbr;
    document.getElementById('register-abbr-preview').textContent = abbr;
  }

  // Surface API errors in the modal instead of leaving it looking frozen
  // after a failed submit. (Ticket #08cec285.)
  function handleRegisterResponse(event) {
    if (event.detail.successful) {
      location.reload();
      return;
    }
    var errorDiv = document.getElementById('register-error');
    var message = 'Registration failed.';
    try {
      var body = JSON.parse(event.detail.xhr.responseText);
      if (body && body.error) message = body.error;
    } catch (e) {
      // Non-JSON response — keep the generic message.
    }
    errorDiv.textContent = message;
    errorDiv.classList.remove('hidden');
  }
</script>
{{/if}}

{{#if projects.length}}
<h3 class="text-sm font-semibold text-gray-400 mb-3">Registered Projects</h3>
<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-navy-700 text-left text-gray-400">
        <th class="pb-3 pr-4 font-medium">Name</th>
        <th class="pb-3 pr-4 font-medium">Type</th>
        <th class="pb-3 pr-4 font-medium w-24">Status</th>
        <th class="pb-3 pr-4 font-medium">Path</th>
        <th class="pb-3 font-medium w-20"></th>
      </tr>
    </thead>
    <tbody>
      {{#each projects}}
      <tr class="border-b border-navy-800 hover:bg-navy-800/50">
        <td class="py-3 pr-4 text-gray-200 font-medium cursor-pointer" onclick="window.location='/ui/projects/{{this.id}}'">{{this.name}}</td>
        <td class="py-3 pr-4 text-gray-400 cursor-pointer" onclick="window.location='/ui/projects/{{this.id}}'">{{this.project_type_id}}</td>
        <td class="py-3 pr-4">
          <span class="badge badge-{{this.status}}">{{this.status}}</span>
        </td>
        <td class="py-3 pr-4 text-gray-500 text-xs font-mono">{{this.path}}</td>
        <td class="py-3 text-right">
          <button onclick="event.stopPropagation(); if(confirm('Archive {{this.name}}?')) { fetch('/api/projects/{{this.id}}', {method:'DELETE'}).then(r => { if(r.ok) location.reload(); else r.json().then(d => alert(d.error)); }); }"
            class="text-xs text-gray-500 hover:text-red-400 transition-colors">
            Archive
          </button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{else}}
{{#unless discovered.length}}
<div class="text-center py-12 text-gray-500">
  <p>No projects found.</p>
  <p class="text-sm mt-2">Add project folders to <code class="text-accent">~/Development/</code> and they'll appear here.</p>
</div>
{{/unless}}
{{/if}}

{{#if discovered.length}}
<!-- Discovered folders — click to register -->
<div class="mb-6">
  <h3 class="text-sm font-semibold text-gray-400 mb-3">Discovered Projects</h3>
  <p class="text-xs text-gray-500 mb-3">Click a folder to add it as a project:</p>
  <div class="flex flex-wrap gap-3">
    {{#each discovered}}
    <div class="discovered-folder card flex items-center gap-3"
         onclick="showRegisterPrompt('{{this.name}}', '{{this.path}}')">
      <span class="text-2xl shrink-0">&#128193;</span>
      <div>
        <p class="text-sm text-gray-200 font-medium">{{this.name}}</p>
        <p class="text-xs text-gray-500 font-mono whitespace-nowrap">{{this.path}}</p>
      </div>
    </div>
    {{/each}}
  </div>
</div>

<!-- Register prompt modal (hidden until a discovered folder is clicked) -->
<div id="register-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
  <div class="bg-navy-800 border border-navy-700 rounded-xl w-96 p-6">
    <h3 class="text-lg font-semibold text-gray-200 mb-1">Register Project</h3>
    <p id="register-folder-name" class="text-sm text-gray-400 mb-4"></p>
    <form hx-post="/api/projects" hx-ext="json-enc" hx-swap="none"
          hx-on::after-request="if(event.detail.successful) location.reload()">
      <input type="hidden" id="register-path" name="path">
      <div class="mb-3">
        <label class="block text-xs text-gray-500 mb-1">Name</label>
        <input id="register-name" name="name" required
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
      </div>
      <div class="mb-4">
        <label class="block text-xs text-gray-500 mb-1">Project Type</label>
        <select name="project_type_id" required
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
          {{#each ../projectTypes}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit"
          class="flex-1 px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">
          Add Project
        </button>
        <button type="button" onclick="document.getElementById('register-modal').classList.add('hidden')"
          class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-300 text-sm rounded-lg transition-colors">
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function showRegisterPrompt(name, path) {
    document.getElementById('register-name').value = name;
    document.getElementById('register-path').value = path;
    document.getElementById('register-folder-name').textContent = path;
    document.getElementById('register-modal').classList.remove('hidden');
  }
</script>
{{/if}}

{{#if projects.length}}
<h3 class="text-sm font-semibold text-gray-400 mb-3">Registered Projects</h3>
<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-navy-700 text-left text-gray-400">
        <th class="pb-3 pr-4 font-medium">Name</th>
        <th class="pb-3 pr-4 font-medium">Type</th>
        <th class="pb-3 pr-4 font-medium w-24">Status</th>
        <th class="pb-3 font-medium">Path</th>
      </tr>
    </thead>
    <tbody>
      {{#each projects}}
      <tr class="border-b border-navy-800 hover:bg-navy-800/50 cursor-pointer"
          onclick="window.location='/ui/projects/{{this.id}}'">
        <td class="py-3 pr-4 text-gray-200 font-medium">{{this.name}}</td>
        <td class="py-3 pr-4 text-gray-400">{{this.project_type_id}}</td>
        <td class="py-3 pr-4">
          <span class="badge badge-{{this.status}}">{{this.status}}</span>
        </td>
        <td class="py-3 text-gray-500 text-xs font-mono">{{this.path}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{else}}
{{#unless discovered.length}}
<div class="text-center py-12 text-gray-500">
  <p>No projects found.</p>
  <p class="text-sm mt-2">Add project folders to <code class="text-accent">~/Development/</code> and they'll appear here.</p>
</div>
{{/unless}}
{{/if}}

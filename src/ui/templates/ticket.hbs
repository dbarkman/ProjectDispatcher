<!-- Ticket header — display mode -->
<div id="ticket-display" class="mb-6">
  <div class="flex items-center gap-3 text-sm text-gray-400 mb-1">
    <span class="priority-dot priority-{{ticket.priority}}"></span>
    <span>{{ticket.priority}}</span>
    <span class="text-gray-600">|</span>
    <span>Column: <strong class="text-gray-300">{{ticket.column}}</strong></span>
    <span class="text-gray-600">|</span>
    <span>{{relativeTime ticket.created_at}}</span>
    <span class="text-gray-600">|</span>
    <span class="font-mono text-xs">{{ticket.displayId}}</span>
    <span class="text-gray-600">|</span>
    <button type="button" onclick="toggleEditMode(true)"
      class="text-accent hover:text-accent-hover text-sm underline">Edit</button>
  </div>
  {{#if ticket.body}}
  <div class="mt-3 text-sm text-gray-300 bg-navy-900 rounded-lg p-4 border border-navy-700 whitespace-pre-wrap">
    {{ticket.body}}
  </div>
  {{/if}}
  {{#if ticket.claimed_by_run_id}}
  <div class="mt-3 text-xs text-accent bg-accent/10 rounded px-3 py-2">
    Agent is working on this ticket (run: {{ticket.claimed_by_run_id}})
  </div>
  {{/if}}
</div>

<!-- Ticket header — edit mode -->
<div id="ticket-edit" class="hidden mb-6 card">
  <h3 class="text-sm font-semibold text-gray-400 mb-3">Edit Ticket</h3>
  <form id="edit-ticket-form" onsubmit="return submitEditForm(event)">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Title</label>
        <input name="title" required maxlength="500" value="{{ticket.title}}"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Priority</label>
        <select name="priority"
          class="w-full bg-navy-900 border border-navy-700 rounded px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
          <option value="low" {{#if (eq ticket.priority "low")}}selected{{/if}}>Low</option>
          <option value="normal" {{#if (eq ticket.priority "normal")}}selected{{/if}}>Normal</option>
          <option value="high" {{#if (eq ticket.priority "high")}}selected{{/if}}>High</option>
          <option value="urgent" {{#if (eq ticket.priority "urgent")}}selected{{/if}}>Urgent</option>
        </select>
      </div>
    </div>
    <div class="mt-3">
      <label class="block text-xs text-gray-500 mb-1">Description</label>
      <textarea name="body" rows="4"
        class="w-full bg-navy-900 border border-navy-700 rounded-lg p-3 text-sm text-gray-200 placeholder-gray-600 focus:border-accent focus:outline-none resize-y">{{ticket.body}}</textarea>
    </div>
    <div class="mt-3 flex gap-2">
      <button type="submit" id="edit-ticket-btn"
        class="px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">Save</button>
      <button type="button" onclick="toggleEditMode(false)"
        class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-300 text-sm rounded-lg transition-colors">Cancel</button>
    </div>
  </form>
</div>
<script>
  function toggleEditMode(editing) {
    document.getElementById('ticket-display').classList.toggle('hidden', editing);
    document.getElementById('ticket-edit').classList.toggle('hidden', !editing);
  }

  async function submitEditForm(e) {
    e.preventDefault();
    const form = document.getElementById('edit-ticket-form');
    const btn = document.getElementById('edit-ticket-btn');
    btn.disabled = true;
    btn.textContent = 'Saving...';

    const payload = {
      title: form.title.value.trim(),
      body: form.body.value,
      priority: form.priority.value,
    };

    try {
      const res = await fetch('/api/tickets/{{ticket.id}}', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        location.reload();
      } else {
        const err = await res.json();
        alert('Save failed: ' + (err.error || 'Unknown error'));
        btn.disabled = false;
        btn.textContent = 'Save';
      }
    } catch {
      alert('Save failed: network error');
      btn.disabled = false;
      btn.textContent = 'Save';
    }
    return false;
  }
</script>

<!-- Quick action buttons (Gap fix #8) -->
<div class="flex gap-2 mb-6">
  {{#if prevColumn}}
  <form hx-post="/api/tickets/{{ticket.id}}/move" hx-ext="json-enc" hx-swap="none"
        hx-on::after-request="if(event.detail.successful) location.reload()">
    <input type="hidden" name="to_column" value="{{prevColumn.column_id}}">
    <input type="hidden" name="author" value="human">
    <button type="submit"
      class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-200 text-sm rounded-lg transition-colors">
      &larr; Send back to {{prevColumn.name}}
    </button>
  </form>
  {{/if}}
  {{#if nextColumn}}
  <form hx-post="/api/tickets/{{ticket.id}}/move" hx-ext="json-enc" hx-swap="none"
        hx-on::after-request="if(event.detail.successful) location.reload()">
    <input type="hidden" name="to_column" value="{{nextColumn.column_id}}">
    <input type="hidden" name="author" value="human">
    <button type="submit"
      class="px-4 py-2 bg-green-700 hover:bg-green-600 text-white text-sm rounded-lg transition-colors">
      Approve to {{nextColumn.name}} &rarr;
    </button>
  </form>
  {{/if}}
  {{#unless (eq ticket.column "done")}}
  <form hx-post="/api/tickets/{{ticket.id}}/move" hx-ext="json-enc" hx-swap="none"
        hx-on::after-request="if(event.detail.successful) location.reload()">
    <input type="hidden" name="to_column" value="done">
    <input type="hidden" name="author" value="human">
    <button type="submit"
      class="px-4 py-2 bg-navy-800 hover:bg-navy-700 text-gray-400 text-sm rounded-lg transition-colors">
      Override to Done
    </button>
  </form>
  {{/unless}}
</div>

<!-- Agent runs (Gap fix #5) -->
{{#if agentRuns.length}}
<div class="mb-6">
  <h3 class="text-sm font-semibold text-gray-400 mb-3">Agent Runs</h3>
  <div class="space-y-2">
    {{#each agentRuns}}
    <div class="card flex items-center justify-between text-sm">
      <div>
        <span class="text-gray-300 font-medium">{{this.agent_type_id}}</span>
        <span class="text-gray-500 text-xs ml-2">{{this.shortId}}</span>
        <span class="ml-2 text-xs
          {{#if (eq this.exit_status 'success')}}text-green-400{{/if}}
          {{#if (eq this.exit_status 'crashed')}}text-red-400{{/if}}
          {{#if (eq this.exit_status 'timeout')}}text-yellow-400{{/if}}
          {{#if (eq this.exit_status 'running')}}text-accent{{/if}}
        ">{{this.exit_status}}</span>
        <span class="text-gray-500 text-xs ml-2">{{this.durationStr}}</span>
      </div>
      {{#if this.hasTranscript}}
      <button onclick="loadTranscript('{{this.id}}')"
        class="text-xs text-accent hover:text-accent-hover underline">
        View Transcript
      </button>
      {{/if}}
    </div>
    {{/each}}
  </div>
</div>
{{/if}}

<!-- Transcript modal (Gap fix #5) -->
<div id="transcript-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
  <div class="bg-navy-900 border border-navy-700 rounded-xl w-[90vw] max-w-4xl max-h-[80vh] flex flex-col">
    <div class="flex items-center justify-between px-4 py-3 border-b border-navy-700">
      <h3 class="text-sm font-semibold text-gray-300">Agent Transcript</h3>
      <button onclick="document.getElementById('transcript-modal').classList.add('hidden')"
        class="text-gray-500 hover:text-gray-300">&times;</button>
    </div>
    <pre id="transcript-content" class="flex-1 overflow-y-auto p-4 text-xs text-gray-300 font-mono whitespace-pre-wrap">Loading...</pre>
  </div>
</div>
<script>
  async function loadTranscript(runId) {
    const modal = document.getElementById('transcript-modal');
    const content = document.getElementById('transcript-content');
    modal.classList.remove('hidden');
    content.textContent = 'Loading...';
    try {
      const res = await fetch(`/api/agent-runs/${runId}/transcript`);
      if (res.ok) {
        content.textContent = await res.text();
      } else {
        const err = await res.json();
        content.textContent = `Error: ${err.error || 'Failed to load transcript'}`;
      }
    } catch {
      content.textContent = 'Error: network failure';
    }
  }
</script>

<!-- Attachments -->
{{#if attachments.length}}
<div class="mb-6">
  <h3 class="text-sm font-semibold text-gray-400 mb-3">Attachments</h3>
  <div class="flex flex-wrap gap-3">
    {{#each attachments}}
    <div class="relative group">
      {{#if this.isImage}}
      <a href="/api/attachments/{{this.id}}/file" target="_blank">
        <img src="/api/attachments/{{this.id}}/file" alt="{{this.filename}}"
          class="h-24 w-24 object-cover rounded-lg border border-navy-700 hover:border-accent/50 transition-colors cursor-pointer">
      </a>
      {{else}}
      <a href="/api/attachments/{{this.id}}/file" target="_blank"
        class="flex items-center gap-2 px-3 py-2 bg-navy-900 border border-navy-700 rounded-lg hover:border-accent/50 transition-colors">
        <span class="text-sm text-gray-300">{{this.filename}}</span>
        <span class="text-xs text-gray-500">{{this.sizeStr}}</span>
      </a>
      {{/if}}
      <button onclick="deleteAttachment('{{this.id}}')"
        class="absolute -top-1 -right-1 bg-red-600 text-white rounded-full w-5 h-5 text-xs leading-none flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
        title="Remove attachment">&times;</button>
    </div>
    {{/each}}
  </div>
</div>
{{/if}}

<!-- Add attachment -->
<div class="mb-6">
  <div id="attachment-drop-zone"
    class="border-2 border-dashed border-navy-700 rounded-lg p-3 text-center cursor-pointer hover:border-accent/50 transition-colors"
    onclick="document.getElementById('attachment-input').click()">
    <p class="text-xs text-gray-500">Click or drag & drop to add screenshots</p>
  </div>
  <input type="file" id="attachment-input" accept="image/*" multiple class="hidden"
    onchange="uploadAttachments(this.files)">
</div>
<script>
  const attachDropZone = document.getElementById('attachment-drop-zone');
  attachDropZone.addEventListener('dragover', function(e) {
    e.preventDefault();
    attachDropZone.classList.add('border-accent/50');
  });
  attachDropZone.addEventListener('dragleave', function() {
    attachDropZone.classList.remove('border-accent/50');
  });
  attachDropZone.addEventListener('drop', function(e) {
    e.preventDefault();
    attachDropZone.classList.remove('border-accent/50');
    if (e.dataTransfer.files.length) uploadAttachments(e.dataTransfer.files);
  });

  async function uploadAttachments(files) {
    for (const file of files) {
      if (!file.type.startsWith('image/')) { alert(file.name + ' is not an image'); continue; }
      if (file.size > 10 * 1024 * 1024) { alert(file.name + ' is too large (max 10 MB)'); continue; }
      const formData = new FormData();
      formData.append('file', file);
      const res = await fetch('/api/tickets/{{ticket.id}}/attachments', {
        method: 'POST',
        body: formData,
      });
      if (!res.ok) {
        const err = await res.json();
        alert('Upload failed: ' + (err.error || 'Unknown error'));
      }
    }
    document.getElementById('attachment-input').value = '';
    location.reload();
  }

  async function deleteAttachment(id) {
    if (!confirm('Remove this attachment?')) return;
    const res = await fetch('/api/attachments/' + id, { method: 'DELETE' });
    if (res.ok) location.reload();
    else alert('Delete failed');
  }
</script>

<!-- Comment thread — auto-refreshes every 5s while the ticket page is open.
     Scrollable so long agent journals don't dominate the page. -->
<div class="mb-8">
  <div class="flex items-center justify-between mb-2">
    <h3 class="text-sm font-semibold text-gray-400">Thread</h3>
    <span class="text-[10px] text-gray-600">auto-refreshing</span>
  </div>
  <div id="comment-thread"
       class="max-h-[50vh] overflow-y-auto pr-2 bg-navy-950/40 border border-navy-800 rounded-lg p-3"
       hx-get="/ui/tickets/{{ticket.id}}/comments"
       hx-trigger="every 5s [document.visibilityState === 'visible']"
       hx-swap="innerHTML">
    {{> commentThread}}
  </div>
</div>

<!-- Actions -->
<div class="border-t border-navy-700 pt-6">
  <h3 class="text-sm font-semibold text-gray-400 mb-3">Add Comment</h3>

  <form hx-post="/api/tickets/{{ticket.id}}/comments" hx-ext="json-enc" hx-swap="none"
        hx-on::after-request="if(event.detail.successful) location.reload()"
        class="mb-4">
    <input type="hidden" name="type" value="comment">
    <input type="hidden" name="author" value="human">
    <textarea name="body" rows="3" placeholder="Add a comment..."
      class="w-full bg-navy-900 border border-navy-700 rounded-lg p-3 text-sm text-gray-200 placeholder-gray-600 focus:border-accent focus:outline-none resize-y"></textarea>
    <button type="submit"
      class="mt-2 px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm rounded-lg transition-colors">
      Comment
    </button>
  </form>

  <div class="border-t border-navy-700 pt-4">
    <h3 class="text-sm font-semibold text-gray-400 mb-3">Move Ticket</h3>
    <form hx-post="/api/tickets/{{ticket.id}}/move" hx-ext="json-enc" hx-swap="none"
          hx-on::after-request="if(event.detail.successful) location.reload()"
          class="flex items-center gap-2">
      <input type="hidden" name="author" value="human">
      <select name="to_column"
        class="bg-navy-900 border border-navy-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:border-accent focus:outline-none">
        {{#each columns}}
        <option value="{{this.column_id}}" {{#if (eq this.column_id ../ticket.column)}}disabled{{/if}}>
          {{this.name}}
        </option>
        {{/each}}
      </select>
      <button type="submit"
        class="px-4 py-2 bg-navy-700 hover:bg-navy-600 text-gray-200 text-sm rounded-lg transition-colors">
        Move
      </button>
    </form>
  </div>
</div>
